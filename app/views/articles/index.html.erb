<h2>Articles</h2>
<p> <%= link_to "CreateNew Article", new_article_path %>
</p>

<table>
    <thead>
    <th>title</th>
    <th>description</th>
    <th>Edit</th>
    <th>Show</th>
    </thead>
    <% @articles.each do |article| %>
    <tr>
        <td> <%= article[:title] %></td>
        <td> <%= article[:description] %></td>
        <td> <%= link_to 'Edit', edit_article_path(article[:id]) %></td>
        <td> <%= link_to 'Show', article_path(article[:id]) %></td>
    </tr>
    <% end %>
</table>