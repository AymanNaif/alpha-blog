<h1>Showing Selected Article</h1>

<h2>title: <%= @article.title %></h2>
<p>description: <%= @article.description %></p>
<p>ID Of Article: <%= @article.id %></p>
<% if @article.user %>
    <p>ID Of User: <%= @article.user_id %></p>
    <p>This Article Created By: <%= @article.user.username %></p>
<% end %>

<p>
<%= link_to 'edit this Article', edit_article_path %>
</p>

<p>
<%= link_to 'Create New Article', new_article_path %>
</p>

<p>
<%= link_to 'Back to all Articles', articles_path %>
</p>